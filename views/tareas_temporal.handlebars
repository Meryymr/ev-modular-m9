<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Módulo 6 - Vista Temporal Handlebars</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container my-5">
    <h1 class="mb-4">Tareas Dinámicas (Servidas con Handlebars y JSON)</h1>
    
    <ul class="list-group">
        {{#each tareas}}
            <li class="list-group-item d-flex justify-content-between align-items-center">
                {{this.titulo}}
                <span class="badge bg-primary">{{this.estado}}</span>
            </li>
        {{/each}}
    </ul>
    
    <p class="mt-4 text-muted small">(*) Esta vista es temporal</p>
</body>
</html>